# auth/.env.example — 컨테이너·운영 환경에서 오버라이드 가능한 키 정착지.
# 실값은 0개, 전부 플레이스홀더다. 로컬 개발(bootRun)은 이 파일이 없어도 application.yml
# 기본값만으로 그대로 동작한다 — 아래 값들은 배포 시점에만 필요하다.
# ⚠️ api와 달리 SPRING_PROFILES_ACTIVE 없음 — auth는 default 프로필 단독(prod/ajp 프로필·가드 전무).
#    "prod 딜레마(SMS 스텁으로 prod 기동 불가)"는 auth 무관 — auth엔 SmsSenderProdGuard 자체가 없다.

# ── [로컬 개발 전용] application.yml 기본값 경로 ────────────────────
#  아래 SPRING_DATASOURCE_* 블록을 설정하면 이 두 키는 "조용히 무시"된다(api 선례 실측).
# DB_NAME=morymaker
# DB_ROOT_PASSWORD=changeme

# ── [컨테이너·운영] datasource 전체를 이 블록이 인수한다 ─────────────
#  ⚠️ 위 블록과 상호배타. 셋 중 하나라도 켜면 URL/계정 해석 주체가 여기로 넘어온다.
SPRING_DATASOURCE_URL=jdbc:mariadb://<db-host>:3306/<db-name>   # ⚠️ 컨테이너 내부 포트는 3306 (13306은 호스트 published)
SPRING_DATASOURCE_USERNAME=<db-user>                            # application.yml 기본 username=root 를 오버라이드
SPRING_DATASOURCE_PASSWORD=<db-password>

# ── [OIDC issuer] iss 클레임·discovery 신뢰 앵커 ──────────────────
#  ⚠️ 운영은 실 도메인(https://mm-accounts.i-commtech.co.kr) 필수 오버라이드.
#     auth엔 issuer 검증 fail-fast 가드가 없다(api ProdIssuerConfigGuard 대응물 부재).
#     잘못된 값이어도 기동은 되고 iss 클레임이 오염된 채 api·web까지 전파되므로 값 주입을 직접 확인할 것.
AUTH_ISSUER=https://<auth-host>

# ── [web OIDC 클라이언트] 4표면(콘솔·실행자·키오스크·방문자) 공유 단일 클라이언트(Next.js BFF) ──
AUTH_WEB_CLIENT_ID=<web-client-id>
AUTH_WEB_CLIENT_SECRET=<web-client-secret>
#  ⚠️ 운영 콜백 필수 주입 — RegisteredClientSeeder가 매 부팅 이 값으로 redirect_uris를 재구성한다
#     (config-authoritative — DB에 수동 등록해도 다음 재시작에 소실된다).
#     기본값은 로컬(http://localhost:3000/app/oauth/callback)만이라, 미주입 시 운영 로그인이
#     조용히 파손된다. 운영: https://mm.i-commtech.co.kr/app/oauth/callback
#     (로컬과 동시 필요 시 콤마로 CSV 합집합 — 로컬 값을 소거하지 말 것)
AUTH_WEB_REDIRECT_URIS=https://mm.i-commtech.co.kr/app/oauth/callback
AUTH_WEB_SCOPES=openid,email

# ── [로그인 잠금 정책] 미설정 시 기본값(5회 / 15m) ───────────────────
# AUTH_LOCK_MAX_ATTEMPTS=5
# AUTH_LOCK_DURATION=15m

# ── [토큰 수명] 미설정 시 기본값(access 30m / refresh 24h) ──────────
# AUTH_ACCESS_TOKEN_TTL=30m
# AUTH_REFRESH_TOKEN_TTL=24h
